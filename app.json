{
  "expo": {
    "name": "FutbolcuTahminEtme",
    "slug": "FutbolcuTahminEtme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futbolcu.tahminetme"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.futbolcu.tahminetme"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "scheme": "futbolcutahmin"
  }
}
